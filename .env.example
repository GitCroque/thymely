# =============================================================================
# Thymely — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set before starting the application.
# Variables marked [OPTIONAL] have sensible defaults and can be left empty.
# =============================================================================

# -----------------------------------------------------------------------------
# Database [REQUIRED]
# -----------------------------------------------------------------------------

# PostgreSQL credentials used by both the database container and the API.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=thymely

# Full connection string for Prisma. In Docker, the host is the service name.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@thymely_postgres:5432/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Security [REQUIRED in production]
# -----------------------------------------------------------------------------

# JWT signing key. In production, must be at least 32 characters, base64-encoded.
# Example: openssl rand -base64 48
SECRET=

# Initial admin account password used by the explicit install/bootstrap step.
# If not set, a random password is generated and printed to stdout during seed.
THYMELY_BOOTSTRAP_PASSWORD=

# AES encryption key for sensitive data at rest (e.g. IMAP credentials).
# Generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=

# Cache TTL for auth/RBAC config lookups, in milliseconds (default: 60000 = 60s).
# Lower values pick up config changes faster; higher values reduce DB queries.
AUTH_CONFIG_CACHE_TTL_MS=60000

# -----------------------------------------------------------------------------
# Network & Proxy
# -----------------------------------------------------------------------------

# Runtime environment. Set to "production" for Docker/production deployments.
NODE_ENV=production

# Public URL of your Thymely instance (e.g. https://help.example.com).
# Used for OAuth/OIDC callback URLs. Falls back to the request Host header.
PUBLIC_APP_URL=

# Comma-separated list of allowed CORS origins (e.g. https://help.example.com).
# Leave empty to use the default (same-origin only).
CORS_ORIGIN=

# Set to true if Thymely runs behind a reverse proxy (nginx, Caddy, Traefik…).
TRUST_PROXY=false

# Set to true when serving over HTTPS to mark session cookies as Secure.
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Public Access [OPTIONAL — both disabled by default for security]
# -----------------------------------------------------------------------------

# Allow unauthenticated users to create accounts via the client portal.
# Enabled by default (helpdesk clients need to sign up). Set to "false" to disable.
ALLOW_EXTERNAL_REGISTRATION=true

# Allow unauthenticated users to submit tickets via the public form.
# Set to "true" only if you want a public ticket intake.
ALLOW_PUBLIC_TICKETS=false

# Bind sessions to the client IP address. Prevents session reuse from
# a different network, but disconnects mobile users switching WiFi/4G.
# Default: false (only user-agent is checked).
SESSION_BIND_IP=false

# -----------------------------------------------------------------------------
# Email [OPTIONAL]
# -----------------------------------------------------------------------------

# Allow connections to IMAP servers with invalid/self-signed TLS certificates.
# Only enable this in trusted network environments.
ALLOW_INSECURE_IMAP_TLS=false

# Allow webhook URLs using http:// (not https://).
# Only enable this for local/development integrations.
ALLOW_INSECURE_WEBHOOK_URLS=false

# -----------------------------------------------------------------------------
# Logging [OPTIONAL]
# -----------------------------------------------------------------------------

# Pino log level. Values: trace, debug, info, warn, error, fatal.
# Logs are written to stdout/stderr. There is no built-in file log viewer.
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Analytics [OPTIONAL]
# -----------------------------------------------------------------------------

# PostHog API key for anonymous usage analytics.
# Leave empty to disable analytics entirely (noop).
POSTHOG_API_KEY=

# -----------------------------------------------------------------------------
# Error Monitoring [OPTIONAL]
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking. Leave empty to disable Sentry entirely.
# Get your DSN from https://sentry.io → Project Settings → Client Keys.
SENTRY_DSN=

# Sentry environment tag (e.g. production, staging). Defaults to NODE_ENV.
SENTRY_ENVIRONMENT=

# Sentry traces sample rate (0.0 to 1.0). Default: 0.1 (10%).
SENTRY_TRACES_SAMPLE_RATE=0.1

# Public Sentry DSN for the frontend (client-side). Same value as SENTRY_DSN
# or a separate project DSN. Prefix with NEXT_PUBLIC_ so Next.js exposes it.
NEXT_PUBLIC_SENTRY_DSN=
