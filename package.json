{
  "private": true,
  "name": "thymely",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo test",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@4.2.2",
  "dependencies": {
    "next": "^16.1.0",
    "nextra": "^4.4.0",
    "nextra-theme-docs": "^4.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
